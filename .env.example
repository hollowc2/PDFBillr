# PDFBillr environment variables. Copy to .env and fill in values.
# Never commit .env to version control.

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Database (optional — defaults to SQLite at instance/pdfbillr.db)
# For production use PostgreSQL: postgresql://user:pass@host:5432/pdfbillr
DATABASE_URL=sqlite:///pdfbillr.db

# OPTIONAL — IPs gunicorn trusts for X-Forwarded-* headers (default: 127.0.0.1)
# If using nginx/Traefik in Docker Compose, set to the Docker bridge subnet e.g. 172.16.0.0/12
FORWARDED_ALLOW_IPS=127.0.0.1

# Stripe — get keys from https://dashboard.stripe.com/apikeys
# Use sk_test_... / pk_test_... for development, sk_live_... / pk_live_... for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret — from `stripe listen` CLI or the Stripe dashboard webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the Pro monthly plan — create in Stripe dashboard under Products
STRIPE_PRICE_ID_PRO=price_...

# Flask-Mail (SMTP) — used for welcome, password reset, and invoice emails
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=you@example.com
MAIL_PASSWORD=yourpassword
MAIL_DEFAULT_SENDER=noreply@pdfbillr.com
