# PDFBillr environment variables. Copy to .env and fill in values.
# Never commit .env to version control.

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# OPTIONAL — IPs gunicorn trusts for X-Forwarded-* headers (default: 127.0.0.1)
# If using nginx/Traefik in Docker Compose, set to the Docker bridge subnet e.g. 172.16.0.0/12
FORWARDED_ALLOW_IPS=127.0.0.1
